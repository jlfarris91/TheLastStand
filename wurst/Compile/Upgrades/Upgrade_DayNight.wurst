package Upgrade_DayNight
import TlsUpgradeIds
import TlsUpgradeDefinition

// ============================================================================
@compiletime function createUpgrade()
  new TlsUpgradeDefinition(TlsUpgradeIds.day, 1)
  ..setName(1, "Day")
  ..setTooltip(1, "Day")
  ..setTooltipExtended(1, "It is currently day.")

  new TlsUpgradeDefinition(TlsUpgradeIds.night, 1)
  ..setName(1, "Night")
  ..setTooltip(1, "Night")
  ..setTooltipExtended(1, "It is currently night.")